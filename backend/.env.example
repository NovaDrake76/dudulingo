# Database
DATABASE_URL=mongodb+srv://username:password@cluster.mongodb.net/dudulingo?retryWrites=true&w=majority&appName=YourApp

# Authentication
JWT_SECRET=your_secure_random_string_minimum_32_characters_long
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Server Configuration
PORT=8000
BASE_URL=http://localhost
API_URL=http://localhost:8000

# Environment
IS_DEV=true
NODE_ENV=development
LOG_LEVEL=http

# Security
ALLOWED_ORIGINS=http://localhost:19000,http://localhost:8081,exp://localhost:8081

# Monitoring (Optional)
SENTRY_DSN=
