{
  "name": "dudulingo-backend",
  "version": "1.0.0",
  "description": "",
  "index.ts": "index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:dev": "node --env-file=.env --watch api/index.ts",
    "dev": "npm run start:dev",
    "lint": "eslint \"api/**/*.{ts,js}\" --max-warnings=0",
    "format": "prettier --write \"api/**/*.{ts,js,json,md}\"",
    "test": "vitest",
    "test:report": "vitest run --coverage --reporter=html",
    "coverage": "vitest run --coverage",
    "coverage:ui": "vitest --ui",
    "db:seed": "tsx api/db/seed.ts",
    "db:setup": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "tsx scripts/run-migration.ts",
    "deck:make": "node --env-file=.env --import tsx/esm scripts/deck-maker.ts",
    "deck:seed": "node --env-file=.env --import tsx/esm scripts/deck-maker.ts --seed"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.19.1",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.36.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/node": "^24.5.2",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.44.1",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "install": "^0.13.0",
    "mongodb-memory-server": "^10.4.1",
    "npm": "^11.6.1",
    "passport-custom": "^1.1.1",
    "prettier": "^3.6.2",
    "supertest": "^7.1.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2",
    "vitest": "^4.0.15"
  }
}
